# --- LLM Provider ---------------------------------------------------------
# Default provider is GigaChat (set GIGA_CREDENTIALS to your token).
# Set AMA_LLM_PROVIDER=echo to use the deterministic echo provider (no API
# calls, useful for offline development and CI).
AMA_LLM_PROVIDER=gigachat

GIGA_CREDENTIALS=your_token

# --- Runtime tuning -------------------------------------------------------
# AMA_TICK_DELAY=0.0           # seconds between cycles in the main loop
# AMA_MAX_BUS_HISTORY=200      # number of recent thoughts each agent sees
# AMA_GENERATION_THRESHOLD=50  # cycles before the next generation may begin
# AMA_DISCOVERY_INTERVAL=10    # cycles between discovery passes
